direction: down

title: {
  label: Data Flow & Storage
  near: top-center
  shape: text
  style: { font-size: 32; bold: true; font-color: "#1a1a2e" }
}

subtitle: {
  label: "How data moves through the factory system"
  near: top-center
  shape: text
  style: { font-size: 16; italic: true; font-color: "#666" }
}

# ── Input Sources ─────────────────────────────────

inputs: {
  label: "Input Sources"
  style: { fill: "#e3f2fd"; stroke: "#1976d2"; border-radius: 12; bold: true; font-size: 16 }

  path: {
    label: "Project Path"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }

  github_url: {
    label: "GitHub URL"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }

  vault_idea: {
    label: "Vault Idea"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }

  raw_prompt: {
    label: "Raw Prompt"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }
}

# ── Configuration ─────────────────────────────────

config: {
  label: "Configuration Layer"
  style: { fill: "#f0f4ff"; stroke: "#5c6bc0"; border-radius: 12; bold: true; font-size: 16 }

  factory_md: {
    label: |md
      **factory.md**
      goal, scope, guards,
      eval command, threshold,
      smoke test, target branch,
      project eval, eval weights,
      hypothesis budget
    |
    shape: document
    style: { fill: "#e8eaf6"; stroke: "#5c6bc0"; border-radius: 6; font-size: 13 }
    width: 240
  }

  config_json: {
    label: ".factory/config.json\n(parsed config)"
    shape: cylinder
    style: { fill: "#e8eaf6"; stroke: "#5c6bc0"; font-size: 13 }
  }

  eval_profile: {
    label: ".factory/eval_profile.json\n(discovered dimensions)"
    shape: cylinder
    style: { fill: "#e8eaf6"; stroke: "#5c6bc0"; font-size: 13 }
  }

  factory_md -> config_json: "factory init --reparse" {
    style: { font-size: 12 }
  }
}

# ── Strategy Layer ────────────────────────────────

strategy: {
  label: "Strategy Layer"
  style: { fill: "#e8f5e9"; stroke: "#2e7d32"; border-radius: 12; bold: true; font-size: 16 }

  observations: {
    label: "observations.md\nlocal analysis +\ncross-project insights"
    shape: document
    style: { fill: "#c8e6c9"; stroke: "#43a047"; border-radius: 6; font-size: 13 }
    width: 220
  }

  research: {
    label: "research.md\nweb research +\nvault synthesis"
    shape: document
    style: { fill: "#c8e6c9"; stroke: "#43a047"; border-radius: 6; font-size: 13 }
    width: 200
  }

  current: {
    label: "current.md\nhypotheses +\npriorities"
    shape: document
    style: { fill: "#c8e6c9"; stroke: "#43a047"; border-radius: 6; font-size: 13 }
    width: 180
  }

  observations -> current
  research -> current
}

# ── Experiment Artifacts ──────────────────────────

experiments: {
  label: "Experiment Artifacts"
  style: { fill: "#fff3e0"; stroke: "#ef6c00"; border-radius: 12; bold: true; font-size: 16 }

  results_tsv: {
    label: "results.tsv\nappend-only history"
    shape: cylinder
    style: { fill: "#ffe0b2"; stroke: "#ef6c00"; font-size: 13 }
  }

  per_exp: {
    label: |md
      **experiments/NNN/**
      - hypothesis.md
      - eval_before.json
      - eval_after.json
      - changes.diff
      - verdict.json
    |
    shape: page
    style: { fill: "#fff8e1"; stroke: "#ff8f00"; border-radius: 6; font-size: 12 }
    width: 200
  }

  reviews: {
    label: |md
      **reviews/**
      - role-latest.md
      - ceo-verdict-role.md
      - archivist-checkpoints.md
    |
    shape: page
    style: { fill: "#fff8e1"; stroke: "#ff8f00"; border-radius: 6; font-size: 12 }
    width: 220
  }

  events: {
    label: "events.jsonl\nagent activity log"
    shape: cylinder
    style: { fill: "#ffe0b2"; stroke: "#ef6c00"; font-size: 13 }
  }
}

# ── External Systems ──────────────────────────────

external: {
  label: "External Systems"
  style: { fill: "#fce4ec"; stroke: "#c62828"; border-radius: 12; bold: true; font-size: 16 }

  github: {
    label: "GitHub\nIssues, PRs, Reviews"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
    width: 200
  }

  vault: {
    label: "Obsidian Vault\nProject dashboards,\nExperiment notes,\nCEO decision patterns"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
    width: 220
  }

  telegram: {
    label: "Telegram\nDigest notifications"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
  }

  dashboard: {
    label: "Live Dashboard\n:8420 SSE stream"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
  }
}

# ── ACE Self-Improvement ─────────────────────────

ace: {
  label: "ACE Self-Improvement"
  style: { fill: "#f3e5f5"; stroke: "#7b1fa2"; border-radius: 12; bold: true; font-size: 16 }

  playbooks: {
    label: "agents/playbooks/*.md\nDO/DON'T rules with\nhelpful/harmful counters"
    shape: document
    style: { fill: "#e1bee7"; stroke: "#8e24aa"; border-radius: 6; font-size: 13 }
    width: 240
  }

  reflect: {
    label: "Reflect\nanalyze experiments"
    shape: rectangle
    style: { fill: "#e1bee7"; stroke: "#8e24aa"; border-radius: 6; font-size: 13 }
  }

  curate: {
    label: "Curate\nmerge + prune"
    shape: rectangle
    style: { fill: "#e1bee7"; stroke: "#8e24aa"; border-radius: 6; font-size: 13 }
  }

  reflect -> curate -> playbooks
}

# ── Flow connections ──────────────────────────────

inputs -> config: "resolve input" {
  style: { font-size: 13 }
}
config -> strategy: "goals & constraints" {
  style: { font-size: 13 }
}
strategy -> experiments: "hypotheses drive experiments" {
  style: { font-size: 13 }
}
experiments -> external: "issues, PRs, vault writes, notifications" {
  style: { font-size: 13 }
}
experiments -> ace: "experiment outcomes feed learning" {
  style: { font-size: 13 }
}
ace -> strategy: "evolved playbooks improve agents" {
  style: { font-size: 13; stroke-dash: 5 }
}
